# ── Target App ─────────────────────────────────────────────────────────────────

# Base URL of your running dev server
TARGET_URL=http://localhost:3000

# Named routes to capture — JSON array of {name, path} objects.
# Each name becomes the filename: screenshots/after/home.png etc.
ROUTES=[{"name":"home","path":"/"},{"name":"dashboard","path":"/dashboard"},{"name":"settings","path":"/settings"}]

# Viewport dimensions
VIEWPORT_W=1280
VIEWPORT_H=800

# ── Watcher ────────────────────────────────────────────────────────────────────

# Directory for the file watcher to monitor (absolute or relative to repo root)
WATCH_DIR=../my-app/src

# Extra ms to wait after last file save before triggering capture (debounce)
DEBOUNCE_MS=2000

# Seconds to wait after debounce for the hot-reload to finish rendering
HOT_RELOAD_S=2

# ── GitOps ─────────────────────────────────────────────────────────────────────

# GitHub repo for `gh pr create` (owner/repo). Leave blank to skip PR creation.
GITHUB_REPO=your-org/your-repo

# Branch that PRs target
BASE_BRANCH=main

# GitHub label applied to visual regression PRs (must already exist in the repo)
PR_LABEL=visual-regression
